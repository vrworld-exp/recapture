# ReCapture — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.dev, .env.staging, .env.prod and fill in real values.
# Obtain values from the team password manager (Bitwarden / 1Password).
# NEVER commit .env.dev / .env.staging / .env.prod to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the recapture-api service (no trailing slash).
# dev:     http://localhost:3000
# staging: https://recapture-api-staging.onrender.com
# prod:    https://recapture-api.onrender.com
API_BASE_URL=

# ── CDN ───────────────────────────────────────────────────────────────────────
# CloudFront base URL for serving 3D model artifacts.
# Used to construct model download and preview URLs.
# NEVER use raw S3 URLs — always CloudFront.
CLOUDFRONT_BASE_URL=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to 'true' or 'false' to enable/disable features per environment.

# Manual capture mode (advanced — bypasses guided ring capture)
FEATURE_MANUAL_CAPTURE=true

# AR placement preview on model ready screen
FEATURE_AR_PREVIEW=true
