# Server
NODE_ENV=development
PORT=3000

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/recapture?retryWrites=true&w=majority

# JWT
JWT_SECRET=<minimum-32-character-random-string>
JWT_EXPIRES_IN=7d

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# S3 Buckets
S3_BUCKET_RAW=msxr-raw-captures
S3_BUCKET_ARTIFACTS=msxr-model-artifacts

# CloudFront
CLOUDFRONT_BASE_URL=https://<your-cloudfront-domain>.cloudfront.net
