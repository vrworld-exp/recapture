# Copy to .env.dev / .env.staging / .env.prod and fill in real values.
# This file is committed. NEVER put real values here.

# ── API ──────────────────────────────────────────────────────────────────────
# Backend base URL (no trailing slash).
#   dev:     http://localhost:3000
#   staging: https://recapture-staging.onrender.com
#   prod:    https://recapture-api.onrender.com
API_BASE_URL=

# ── Firebase (P1 — leave empty until Firebase is configured) ─────────────────
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
